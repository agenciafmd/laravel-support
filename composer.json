{
    "name": "agenciafmd/laravel-support",
    "description": "Itens uteis para serem utilizados nos projetos",
    "homepage": "https://github.com/agenciafmd/laravel-support",
    "authors": [
        {
            "name": "Irineu Junior",
            "email": "irineu@fmd.ag",
            "homepage": "https://fmd.ag/",
            "role": "Developer"
        }
    ],
    "require": {
        "laravel/framework": "^12.0|^13.0",
        "geekcom/validator-docs": "^3.12",
        "intervention/image-laravel": "^1.5",
        "spatie/image-optimizer": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "Agenciafmd\\Support\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Agenciafmd\\Support\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Agenciafmd\\Support\\Providers\\SupportServiceProvider"
            ],
            "aliases": {
                "Helper": "\\Facades\\Agenciafmd\\Support\\Helper"
            }
        }
    },
    "config": {
        "sort-packages": true
    }
}
